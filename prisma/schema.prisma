
generator client {
  provider = "prisma-client"
  output   = "../src/prisma/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  CREATOR
  ADMIN
}

enum ClaimStatus {
  ACTIVE
  UNCLAIMED
  PENDING_CLAIM
}

enum CreatorBlockType {
  HEADING
  RICH_TEXT
  IMAGE
  GALLERY
  SOUNDCLOUD_TRACK
  SOUNDCLOUD_PLAYLIST
  YOUTUBE_VIDEO
  SPOTIFY_EMBED
  SOCIAL_LINKS
  LINK_LIST
  GIG_LIST
  PAST_GIGS
  CONTENT_LIST
  DIVIDER
  SPACER
  CUSTOM_EMBED
}

enum HomeGigSection {
  FEATURED
  PAST
}

enum HomeContentSection {
  FEATURED
  PAST
}

enum GigMode {
  NORMAL
  TO_BE_ANNOUNCED
}

model User {
  id               String        @id
  name             String
  email            String
  emailVerified    Boolean       @default(false)
  image            String?
  roles            UserRoleAssignment[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @default(now()) @updatedAt
  sessions         Session[]
  accounts         Account[]
  activities       ActivityLog[] @relation("UserActivities")
  targetActivities ActivityLog[] @relation("TargetUserActivities")
  creatorProfile   CreatorProfile?
  creatorClaimRequests CreatorClaimRequest[] @relation("ClaimRequestingUser")

  @@unique([email])
  @@map("user")
}

model UserRoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  role      UserRole
  createdAt DateTime @default(now())
  createdBy String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([role])
  @@map("user_role_assignment")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
  @@index([identifier])
}

model Invite {
  id        String    @id @default(cuid())
  email     String
  role      UserRole  @default(USER)
  used      Boolean   @default(false)
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String? // Optional: track who created the invite

  @@unique([email])
  @@map("invite")
}

model CrewMember {
  id               String   @id @default(cuid())
  name             String
  role             String?
  instagram        String?
  soundcloud       String?
  image            String?
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Optional link to a creator profile. When set, the crew card on the public
  // page becomes clickable and links to the profile.
  creatorProfileId String?
  creatorProfile   CreatorProfile? @relation(fields: [creatorProfileId], references: [id], onDelete: SetNull)

  @@index([creatorProfileId])
  @@map("crew_member")
}

enum ContentLinkType {
  SOUNDCLOUD_TRACK
  SOUNDCLOUD_PLAYLIST
  YOUTUBE_VIDEO
  OTHER
}

model ContentItem {
  id          String          @id @default(cuid())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  type        String
  title       String
  dj          String?
  description String
  date        DateTime

  platform    String?

  link        String
  linkType    ContentLinkType @default(OTHER)
  embedUrl    String?
  

  homeContentPlacements HomeContentPlacement[]

  @@map("content_item")
}

model HomeContentPlacement {
  id        String             @id @default(cuid())
  section   HomeContentSection
  sortOrder Int                @default(0)

  contentItemId String
  contentItem   ContentItem @relation(fields: [contentItemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([section, contentItemId])
  @@index([section, sortOrder])
  @@map("home_content_placement")
}

model GigTag {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gigTags GigTagRelationship[]

  @@map("gig_tag")
}

model GigTagRelationship {
  id        String   @id @default(cuid())
  gigId     String
  gigTagId  String
  gig       Gig      @relation(fields: [gigId], references: [id], onDelete: Cascade)
  gigTag    GigTag   @relation(fields: [gigTagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("gig_tag_relationship")
}

model Gig {
  id           String    @id @default(cuid())
  title        String
  subtitle     String
  shortDescription String?
  /// Rich description stored as a serialized Lexical editor state
  /// (`SerializedEditorState`). Replaces the old markdown `description`
  /// column — see `prisma/migrate-gig-descriptions-lexical.ts` history.
  descriptionLexical Json?
  mode         GigMode  @default(NORMAL)
  gigStartTime DateTime
  gigEndTime   DateTime?
  ticketLink   String?

  // Optional "poster" image for this gig (stored as a file_upload record)
  posterFileUploadId String?

  // Home/site ordering controls
  // - `isFeatured`: whether this gig is eligible for the featured slot (used on home + can be reused elsewhere)
  // - `featuredSortOrder`: lower shows earlier among featured gigs
  // - `pastSortOrder`: lower shows earlier in past gigs lists
  isFeatured        Boolean @default(false)
  featuredSortOrder Int     @default(0)
  pastSortOrder     Int     @default(0)

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  media     GigMedia[]

  gigTags           GigTagRelationship[]
  homeGigPlacements HomeGigPlacement[]
  gigCreators       GigCreator[]

  @@index([posterFileUploadId])
  @@map("gig")
}

model CreatorProfile {
  id               String       @id @default(cuid())
  userId           String?      @unique
  createdByAdminId String?
  claimStatus      ClaimStatus  @default(ACTIVE)
  handle           String       @unique
  displayName      String
  tagline          String?
  bio              String?      @db.Text
  avatarFileId     String?
  bannerFileId     String?
  accentColor      String?
  theme            String?
  isPublished      Boolean      @default(false)
  gridCols         Int          @default(12)
  rowHeightPx      Int          @default(60)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user          User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  blocks        CreatorBlock[]
  socials       CreatorSocial[]
  gigCreators   GigCreator[]
  crewMembers   CrewMember[]
  claimRequests CreatorClaimRequest[]

  @@index([claimStatus])
  @@map("creator_profile")
}

model CreatorBlock {
  id        String           @id @default(cuid())
  profileId String
  type      CreatorBlockType
  x         Int
  y         Int
  w         Int
  h         Int
  data      Json
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  profile CreatorProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, y, x])
  @@map("creator_block")
}

model CreatorSocial {
  id        String  @id @default(cuid())
  profileId String
  platform  String
  url       String
  label     String?
  sortOrder Int     @default(0)

  profile CreatorProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, sortOrder])
  @@map("creator_social")
}

model CreatorClaimRequest {
  id               String    @id @default(cuid())
  profileId        String
  requestingUserId String
  message          String?
  status           String    @default("PENDING")
  decidedByAdminId String?
  decidedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  profile        CreatorProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  requestingUser User           @relation("ClaimRequestingUser", fields: [requestingUserId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([requestingUserId])
  @@index([status])
  @@map("creator_claim_request")
}

model GigCreator {
  id               String   @id @default(cuid())
  gigId            String
  creatorProfileId String
  role             String?
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  gig            Gig            @relation(fields: [gigId], references: [id], onDelete: Cascade)
  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  @@unique([gigId, creatorProfileId])
  @@index([creatorProfileId])
  @@index([gigId, sortOrder])
  @@map("gig_creator")
}

model HomeGigPlacement {
  id        String         @id @default(cuid())
  section   HomeGigSection
  sortOrder Int            @default(0)

  gigId String
  gig   Gig    @relation(fields: [gigId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([section, gigId])
  @@index([section, sortOrder])
  @@map("home_gig_placement")
}

model GigMedia {
  id           String   @id @default(cuid())
  gigId        String
  gig          Gig      @relation(fields: [gigId], references: [id], onDelete: Cascade)
  type         String // "photo" or "video"
  // File upload ID (references file_upload.id via for="gig_media", forId=id)
  fileUploadId String?
  url          String? // Legacy field for backwards compatibility
  // Sorting - separate sort orders for featured and gallery sections
  section      String   @default("gallery") // "featured" or "gallery"
  sortOrder    Int      @default(0) // Sort order within section
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([gigId, section, sortOrder])
  @@index([fileUploadId])
  @@map("gig_media")
}

model MerchItem {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  image       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("merch_item")
}

/// Cached Shopify Storefront products; populated by admin sync.
model ShopifyProductCache {
  id               String   @id @default(cuid())
  shopifyProductId String   @unique
  handle           String
  variantId        String?
  title            String
  description      String
  price            Float
  currencyCode     String
  imageUrl         String?
  /// JSON array of variants from Storefront API (stored as string for reliable Prisma/DB support)
  variantsJson     String?  @db.Text
  sortOrder        Int      @default(0)
  syncedAt         DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([sortOrder])
  @@map("shopify_product_cache")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contact_submission")
}

model NewsletterSubscription {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  removed Boolean @default(false)

  @@map("newsletter_subscription")
}

enum FileUploadStatus {
  NO_FILE
  UPLOADING
  OK
  SOFT_DELETED
  DELETED
  ERRORED
}

enum FileCategory {
  IMAGE
  VIDEO
  AUDIO
  PDF
  DOCUMENT
  FILE
}

model file_tag {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  fileUploads file_upload[]

  @@map("file_tag")
}

model file_upload {
  id        String   @id @unique @default(uuid())
  createdAt DateTime @default(now())

  url      String           @unique
  key      String           @unique
  name     String
  type     String
  size     Int
  mimeType String
  acl      String           @default("private")
  status   FileUploadStatus @default(OK)

  category FileCategory @default(FILE)

  fileTags file_tag[]

  hash String?

  // Image/video dimensions (null for non-media files)
  width  Int?
  height Int?

  userId String?

  for   String
  forId String

  @@index([url])
  @@index([key])
  @@index([name])
  @@index([type])
  @@index([createdAt])
  @@index([size])
  @@index([for, forId])
  @@index([hash])
}

enum RentalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DiscountType {
  FIXED_AMOUNT
  PERCENTAGE
}

enum DiscountRuleMode {
  TOTAL
  PER_ITEM
}

model GearItem {
  id                   String                    @id @default(cuid())
  name                 String
  shortName            String?
  description          String?
  quantity             Int                       @default(1)
  price                Float                     @default(0)
  image                String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  packageItems         GearPackageItem[]
  rentalItems          RentalItem[]
  discountRequirements DiscountRuleRequirement[]

  @@map("gear_item")
}

model GearPackage {
  id          String            @id @default(cuid())
  name        String
  shortName   String?
  description String?
  price       Float
  image       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  items       GearPackageItem[]
  rentals     Rental[]

  @@map("gear_package")
}

model GearPackageItem {
  id            String      @id @default(cuid())
  gearPackageId String
  gearItemId    String
  quantity      Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  gearPackage   GearPackage @relation(fields: [gearPackageId], references: [id], onDelete: Cascade)
  gearItem      GearItem    @relation(fields: [gearItemId], references: [id], onDelete: Cascade)

  @@unique([gearPackageId, gearItemId])
  @@index([gearItemId])
  @@map("gear_package_item")
}

model Rental {
  id                    String        @id @default(cuid())
  packageId             String?
  gearPackage           GearPackage?  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  userName              String
  contactInfo           String
  startDate             DateTime
  endDate               DateTime
  status                RentalStatus  @default(PENDING)
  baseDailyPrice        Float         @default(0)
  discountDailyAmount   Float         @default(0)
  discountedDailyPrice  Float         @default(0)
  estimatedTotalPrice   Float         @default(0)
  appliedDiscountRuleId String?
  appliedDiscountName   String?
  appliedDiscountMode   DiscountRuleMode?
  appliedDiscountType   DiscountType?
  appliedDiscountValue  Float?
  rentalItems           RentalItem[]
  appliedDiscountRule   DiscountRule? @relation(fields: [appliedDiscountRuleId], references: [id], onDelete: SetNull)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@map("rental")
}

model RentalItem {
  id         String   @id @default(cuid())
  rentalId   String
  gearItemId String
  quantity   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  rental     Rental   @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  gearItem   GearItem @relation(fields: [gearItemId], references: [id], onDelete: Cascade)

  @@unique([rentalId, gearItemId])
  @@index([gearItemId])
  @@map("rental_item")
}

model DiscountRule {
  id              String                    @id @default(cuid())
  name            String
  isActive        Boolean                   @default(true)
  discountMode    DiscountRuleMode          @default(TOTAL)
  discountType    DiscountType
  discountValue   Float                     @default(0)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  requirements    DiscountRuleRequirement[]
  appliedRentals  Rental[]

  @@map("discount_rule")
}

model DiscountRuleRequirement {
  id             String       @id @default(cuid())
  discountRuleId String
  gearItemId     String
  requiredQty    Int
  discountValue  Float      @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  discountRule   DiscountRule @relation(fields: [discountRuleId], references: [id], onDelete: Cascade)
  gearItem       GearItem     @relation(fields: [gearItemId], references: [id], onDelete: Cascade)

  @@unique([discountRuleId, gearItemId])
  @@index([gearItemId])
  @@map("discount_rule_requirement")
}

enum ActivityType {
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  USER_ROLE_CHANGED
  INVITE_CREATED
  INVITE_DELETED
  GIG_CREATED
  GIG_UPDATED
  GIG_DELETED
  CONTENT_CREATED
  CONTENT_UPDATED
  CONTENT_DELETED
  CREW_MEMBER_CREATED
  CREW_MEMBER_UPDATED
  CREW_MEMBER_DELETED
  CREW_MEMBER_PROFILE_LINKED
  CREW_MEMBER_PROFILE_UNLINKED
  GEAR_CREATED
  GEAR_UPDATED
  GEAR_DELETED
  PACKAGE_CREATED
  PACKAGE_UPDATED
  PACKAGE_DELETED
  RENTAL_CREATED
  RENTAL_UPDATED
  RENTAL_DELETED
  RENTAL_APPROVED
  RENTAL_REJECTED
  DISCOUNT_RULE_CREATED
  DISCOUNT_RULE_UPDATED
  DISCOUNT_RULE_DELETED
  FILE_UPLOADED
  FILE_DELETED
  LOGIN
  LOGOUT
  USER_ROLE_ADDED
  USER_ROLE_REMOVED
  CREATOR_PROFILE_CREATED
  CREATOR_PROFILE_UPDATED
  CREATOR_PROFILE_PUBLISHED
  CREATOR_PROFILE_UNPUBLISHED
  CREATOR_PROFILE_DELETED
  CREATOR_PROFILE_LINKED
  CREATOR_PROFILE_UNLINKED
  CREATOR_BLOCK_CREATED
  CREATOR_BLOCK_UPDATED
  CREATOR_BLOCK_DELETED
  CREATOR_CLAIM_REQUESTED
  CREATOR_CLAIM_APPROVED
  CREATOR_CLAIM_REJECTED
  GIG_CREATOR_ADDED
  GIG_CREATOR_REMOVED
  OTHER
}

model ActivityLog {
  id           String       @id @default(cuid())
  type         ActivityType
  action       String // Human-readable action description
  details      String? // JSON string with additional details
  userId       String? // User who performed the action
  targetUserId String? // User who was affected (if applicable)
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime     @default(now())

  // Relations
  user       User? @relation("UserActivities", fields: [userId], references: [id], onDelete: SetNull)
  targetUser User? @relation("TargetUserActivities", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([targetUserId])
  @@index([type])
  @@index([createdAt])
  @@map("activity_log")
}

model KeyValueStore {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("key_value_store")
  @@index([key])
}
